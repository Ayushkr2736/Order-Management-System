{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "dest": "/backend/src/index.js" },
    { "source": "/(.*)", "dest": "/frontend/build/$1" }
  ],
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ]
}
